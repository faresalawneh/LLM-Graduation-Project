{
  "title": "LLM Inference Observability",
  "panels": [
    {
      "title": "TTFT (ms)",
      "targets": [{ "expr": "ttft_ms", "legendFormat": "{{scenario}}" }],
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "type": "graph",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "steady" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }]
          },
          {
            "matcher": { "id": "byName", "options": "burst" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }]
          },
          {
            "matcher": { "id": "byName", "options": "stress" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }]
          }
        ]
      }
    },
    {
      "title": "Throughput (tokens/s)",
      "targets": [{ "expr": "throughput_tokens_per_sec", "legendFormat": "{{scenario}}" }],
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "type": "graph",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "steady" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }]
          },
          {
            "matcher": { "id": "byName", "options": "burst" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }]
          },
          {
            "matcher": { "id": "byName", "options": "stress" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }]
          }
        ]
      }
    },
    {
      "title": "GPU Utilization (%)",
      "targets": [{ "expr": "DCGM_FI_DEV_GPU_UTIL", "legendFormat": "GPU {{gpu}}" }],
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "type": "graph"
    },
    {
      "title": "GPU Memory Used (MiB)",
      "targets": [{ "expr": "DCGM_FI_DEV_FB_USED", "legendFormat": "GPU {{gpu}}" }],
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "type": "graph"
    },
    {
      "title": "P95 Request Latency (ms)",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le)) * 1000", "legendFormat": "P95 Latency" }],
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Queue Depth (Waiting Requests)",
      "targets": [{ "expr": "vllm:num_requests_waiting", "legendFormat": "Queue Depth" }],
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "SM Clock (MHz)",
      "targets": [{ "expr": "DCGM_FI_DEV_SM_CLOCK", "legendFormat": "GPU {{gpu}}" }],
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "type": "timeseries"
    },
    {
      "title": "Power Usage (W)",
      "targets": [{ "expr": "DCGM_FI_DEV_POWER_USAGE", "legendFormat": "GPU {{gpu}}" }],
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "type": "timeseries"
    },
    {
      "title": "Running Requests",
      "targets": [{ "expr": "vllm:num_requests_running", "legendFormat": "Running" }],
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "type": "timeseries"
    },
    {
      "title": "KV Cache Usage (%)",
      "targets": [{ "expr": "vllm:gpu_cache_usage_perc * 100", "legendFormat": "KV Cache" }],
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "GPU Temperature (°C)",
      "targets": [{ "expr": "DCGM_FI_DEV_GPU_TEMP", "legendFormat": "GPU {{gpu}}" }],
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "type": "timeseries"
    }
  ],
  "schemaVersion": 27
}