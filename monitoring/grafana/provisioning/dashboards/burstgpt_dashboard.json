{
  "title": "BurstGPT Real Replay",
  "panels": [
    {
      "title": "TTFT (ms) - Real Replay",
      "targets": [{ "expr": "ttft_ms", "legendFormat": "{{scenario}}" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "steady" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }]
          },
          {
            "matcher": { "id": "byName", "options": "burst" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }]
          }
        ]
      }
    },
    {
      "title": "Request Latency (ms) - Real Replay",
